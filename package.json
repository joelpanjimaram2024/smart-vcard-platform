{
  "name": "smart-vcard-platform",
  "private": true,
  "version": "1.0.0",
  "description": "Enterprise Smart vCard Platform with Digital Business Cards, QR Codes, and Analytics",
  "type": "module",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:server": "tsx server.ts",
    "build": "cd frontend && npm run build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "cd frontend && npm run preview",
    "clean": "rm -rf dist frontend/dist frontend/.output",
    "lint": "cd frontend && npm run lint",
    "format": "prettier --write \"**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.0",
    "prettier": "^3.7.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "vcard",
    "business-card",
    "qr-code",
    "digital",
    "networking",
    "saas"
  ],
  "author": "",
  "license": "MIT"
}